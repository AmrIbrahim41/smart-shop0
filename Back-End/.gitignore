# 1. البيئة الوهمية (مساحتها كبيرة جداً وممنوع تترفع)
venv/
.venv/
env/
ENV/

# 2. المتغيرات السرية والباسوردات (أهم حاجة!)
.env
.env.local

# 3. قاعدة البيانات المحلية (عشان متعملش مشاكل مع سيرفر الرفع)
